generator client {
  provider = "prisma-client-js"
  output   = "../../backend/src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AuthProvider {
  LOCAL
}

enum ResumeStatus {
  DRAFT
  FORGED
  FAILED
}

enum JobAnalysisStatus {
  PENDING
  COMPLETED
  FAILED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LanguageLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  FLUENT
  NATIVE
}

enum LinkType {
  LINKEDIN
  GITHUB
  PORTFOLIO
  WEBSITE
  OTHER
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  passwordHash      String
  role              UserRole            @default(USER)
  authProvider      AuthProvider        @default(LOCAL)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  profile           UserProfile?
  baseResume        BaseResume?
  passwordResets    PasswordResetToken[]
  jobAnalyses       JobAnalysis[]
  forgedResumes     ForgedResume[]

  @@index([email])
  @@map("users")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  headline    String?
  phone       String?
  city        String?
  state       String?
  country     String?
  summary     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model BaseResume {
  id              String              @id @default(cuid())
  userId          String              @unique
  title           String              @default("Curriculo base")
  professionalSummary String?         @db.Text
  originalPdfUrl  String?
  originalPdfName String?
  originalPdfPath String?
  originalPdfMimeType String?
  originalPdfSize Int?
  originalPdfText String?             @db.LongText
  originalPdfUploadedAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  education       Education[]
  experiences     WorkExperience[]
  projects        Project[]
  skills          Skill[]
  certifications  Certification[]
  courses         Course[]
  languages       Language[]
  professionalLinks ProfessionalLink[]

  @@map("base_resumes")
}

model Education {
  id            String      @id @default(cuid())
  baseResumeId  String
  institution   String
  degree        String
  fieldOfStudy  String?
  startDate     DateTime?
  endDate       DateTime?
  isCurrent     Boolean     @default(false)
  description   String?     @db.Text
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  baseResume    BaseResume  @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@map("education")
}

model WorkExperience {
  id             String      @id @default(cuid())
  baseResumeId   String
  company        String
  position       String
  location       String?
  startDate      DateTime?
  endDate        DateTime?
  isCurrent      Boolean     @default(false)
  description    String?     @db.Text
  achievements   Json?
  technologies   Json?
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  baseResume     BaseResume  @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@map("work_experiences")
}

model Project {
  id            String      @id @default(cuid())
  baseResumeId  String
  name          String
  description   String?     @db.Text
  role          String?
  url           String?
  repositoryUrl String?
  technologies  Json?
  highlights    Json?
  startDate     DateTime?
  endDate       DateTime?
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  baseResume    BaseResume  @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@map("projects")
}

model Skill {
  id            String      @id @default(cuid())
  baseResumeId  String
  name          String
  category      String?
  level         SkillLevel?
  yearsOfExperience Int?
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  baseResume    BaseResume  @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@index([name])
  @@map("skills")
}

model Certification {
  id             String      @id @default(cuid())
  baseResumeId   String
  name           String
  issuer         String
  credentialId   String?
  credentialUrl  String?
  issuedAt       DateTime?
  expiresAt      DateTime?
  doesNotExpire  Boolean     @default(false)
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  baseResume     BaseResume  @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@map("certifications")
}

model Course {
  id            String      @id @default(cuid())
  baseResumeId  String
  name          String
  provider      String?
  workloadHours Int?
  completedAt   DateTime?
  certificateUrl String?
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  baseResume    BaseResume  @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@map("courses")
}

model Language {
  id            String        @id @default(cuid())
  baseResumeId  String
  name          String
  level         LanguageLevel
  certification String?
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  baseResume    BaseResume    @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@map("languages")
}

model ProfessionalLink {
  id            String      @id @default(cuid())
  baseResumeId  String
  type          LinkType
  label         String?
  url           String
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  baseResume    BaseResume  @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)

  @@index([baseResumeId])
  @@map("professional_links")
}

model JobAnalysis {
  id                String            @id @default(cuid())
  userId            String
  title             String?
  company           String?
  jobDescription    String            @db.LongText
  status            JobAnalysisStatus @default(PENDING)
  score             Int?
  summary           String?           @db.Text
  foundKeywords     Json?
  missingKeywords   Json?
  rawAiResponse     Json?
  errorMessage      String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  forgedResumes     ForgedResume[]

  @@index([userId])
  @@index([status])
  @@map("job_analyses")
}

model ForgedResume {
  id                 String       @id @default(cuid())
  userId             String
  jobAnalysisId      String
  title              String
  status             ResumeStatus @default(DRAFT)
  score              Int
  optimizedSummary   String       @db.Text
  selectedSkills     Json
  selectedExperiences Json
  selectedProjects   Json
  foundKeywords      Json?
  missingKeywords    Json?
  pdfUrl             String?
  htmlSnapshot       String?      @db.LongText
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobAnalysis        JobAnalysis  @relation(fields: [jobAnalysisId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobAnalysisId])
  @@index([status])
  @@map("forged_resumes")
}
