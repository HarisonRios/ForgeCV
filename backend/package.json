{
  "name": "forgecv-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ForgeCV backend API built with Express, TypeScript, Prisma and MySQL.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema ../database/prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema ../database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ../database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "groq-sdk": "^1.2.1",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^25.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
